  "NumPy Neural Network Imports": {
    "prefix": "$1",
    "body": [
      "import numpy as np",
      "import matplotlib.pyplot as plt",
      "np.set_printoptions(linewidth=5000, precision=3)"
    ],
    "description": "NumPy neural network imports"
  },

  "Activation Functions": {
    "prefix": "$2",
    "body": [
      "def act(Z, t):",
      "    if t == 'relu': return np.maximum(0, Z)",
      "    if t == 'sigmoid': return 1 / (1 + np.exp(-Z))",
      "    if t == 'tanh': return np.tanh(Z)"
    ],
    "description": "Activation functions"
  },

  "Activation Derivatives": {
    "prefix": "$3",
    "body": [
      "def act_d(A, t):",
      "    if t == 'relu': return (A > 0).astype(float)",
      "    if t == 'sigmoid': return A * (1 - A)",
      "    if t == 'tanh': return 1 - A**2"
    ],
    "description": "Activation derivatives"
  },

  "Softmax Function": {
    "prefix": "$4",
    "body": [
      "def softmax(Z):",
      "    expZ = np.exp(Z - np.max(Z, axis=0, keepdims=True))",
      "    return expZ / np.sum(expZ, axis=0, keepdims=True)"
    ],
    "description": "Softmax activation"
  },

  "Initialize Parameters": {
    "prefix": "$5",
    "body": [
      "def init(layers):",
      "    n,h1,h2,c = layers",
      "",
      "    W1 = np.random.randn(h1, n) * np.sqrt(2/n)",
      "    b1 = np.zeros((h1,1))",
      "",
      "    W2 = np.random.randn(h2,h1) * np.sqrt(2/h1)",
      "    b2 = np.zeros((h2,1))",
      "",
      "    W3 = np.random.randn(c,h2) * np.sqrt(2/h2)",
      "    b3 = np.zeros((c,1))",
      "",
      "    return [W1,b1,W2,b2,W3,b3]"
    ],
    "description": "Initialize weights and biases"
  },

  "One Hot Encoding": {
    "prefix": "$6",
    "body": [
      "def one_hot(y, num_classes):",
      "    y_oh = np.zeros((num_classes, len(y)))",
      "    y_oh[y, np.arange(len(y))] = 1",
      "    return y_oh"
    ],
    "description": "One hot encoding"
  },

  "Forward Propagation": {
    "prefix": "$7",
    "body": [
      "def forward(X, params, act1, act2):",
      "",
      "    W1,b1,W2,b2,W3,b3 = params",
      "",
      "    Z1 = W1 @ X + b1",
      "    A1 = act(Z1, act1)",
      "",
      "    Z2 = W2 @ A1 + b2",
      "    A2 = act(Z2, act2)",
      "",
      "    Z3 = W3 @ A2 + b3",
      "    A3 = softmax(Z3)",
      "",
      "    return A3, (A1,A2,A3)"
    ],
    "description": "Forward propagation"
  },

  "Compute Loss": {
    "prefix": "$8",
    "body": [
      "def compute_loss(y_oh, y_pred):",
      "    m = y_oh.shape[1]",
      "    return -np.sum(y_oh * np.log(y_pred + 1e-8)) / m"
    ],
    "description": "Cross entropy loss"
  },

  "Backward Propagation": {
    "prefix": "$9",
    "body": [
      "def backward(X, y_oh, params, cache, act1, act2):",
      "",
      "    W1,b1,W2,b2,W3,b3 = params",
      "    A1,A2,A3 = cache",
      "",
      "    m = X.shape[1]",
      "",
      "    dZ3 = A3 - y_oh",
      "    dW3 = dZ3 @ A2.T / m",
      "    db3 = np.sum(dZ3, axis=1, keepdims=True) / m",
      "",
      "    dZ2 = (W3.T @ dZ3) * act_d(A2, act2)",
      "    dW2 = dZ2 @ A1.T / m",
      "    db2 = np.sum(dZ2, axis=1, keepdims=True) / m",
      "",
      "    dZ1 = (W2.T @ dZ2) * act_d(A1, act1)",
      "    dW1 = dZ1 @ X.T / m",
      "    db1 = np.sum(dZ1, axis=1, keepdims=True) / m",
      "",
      "    return [dW1,db1,dW2,db2,dW3,db3]"
    ],
    "description": "Backward propagation"
  },

  "Update Parameters": {
    "prefix": "$10",
    "body": [
      "def update(params, grads, lr):",
      "",
      "    W1,b1,W2,b2,W3,b3 = params",
      "    dW1,db1,dW2,db2,dW3,db3 = grads",
      "",
      "    W1 -= lr * dW1",
      "    b1 -= lr * db1",
      "    W2 -= lr * dW2",
      "    b2 -= lr * db2",
      "    W3 -= lr * dW3",
      "    b3 -= lr * db3",
      "",
      "    return [W1,b1,W2,b2,W3,b3]"
    ],
    "description": "Update parameters using gradient descent"
  },

  "Training Function": {
    "prefix": "$11",
    "body": [
      "def train(X, y, layers, epochs=50, lr=0.1, act1='relu', act2='relu'):",
      "",
      "    params = init(layers)",
      "    y_oh = one_hot(y, layers[-1])",
      "",
      "    loss = []",
      "    acc = []",
      "",
      "    for i in range(epochs):",
      "",
      "        y_pred, cache = forward(X, params, act1, act2)",
      "",
      "        l = compute_loss(y_oh, y_pred)",
      "",
      "        grads = backward(",
      "            X, y_oh, params, cache, act1, act2",
      "        )",
      "",
      "        params = update(params, grads, lr)",
      "",
      "        a = accuracy(y, y_pred)",
      "",
      "        acc.append(a)",
      "        loss.append(l)",
      "",
      "        if i % 10 == 0:",
      "            print(f\"Epoch {i+1} Loss = {l:.4f} Accuracy = {a:.2f}\")",
      "",
      "    return params, loss, acc"
    ],
    "description": "Training function"
  },

  "Accuracy Function": {
    "prefix": "$12",
    "body": [
      "def accuracy(y, y_pred):",
      "    preds = np.argmax(y_pred, axis=0)",
      "    return np.mean(y == preds)"
    ],
    "description": "Accuracy calculation"
  },

  "Evaluate Function": {
    "prefix": "$13",
    "body": [
      "def evaluate(X, y, params, act1, act2):",
      "    y_pred, _ = forward(X, params, act1, act2)",
      "    preds = np.argmax(y_pred, axis=0)",
      "    return preds"
    ],
    "description": "Evaluate neural network"
  },

  "Metrics Function": {
    "prefix": "$14",
    "body": [
      "def metrics(y_true, y_pred, num_classes):",
      "",
      "    accuracy = np.mean(y_true == y_pred)",
      "",
      "    precision_list = []",
      "    recall_list = []",
      "    f1_list = []",
      "",
      "    for c in range(num_classes):",
      "",
      "        tp = np.sum((y_pred == c) & (y_true == c))",
      "        fp = np.sum((y_pred == c) & (y_true != c))",
      "        fn = np.sum((y_pred != c) & (y_true == c))",
      "",
      "        precision = tp / (tp + fp + 1e-8)",
      "        recall = tp / (tp + fn + 1e-8)",
      "",
      "        f1 = 2 * precision * recall / (precision + recall + 1e-8)",
      "",
      "        precision_list.append(precision)",
      "        recall_list.append(recall)",
      "        f1_list.append(f1)",
      "",
      "    return (",
      "        accuracy,",
      "        np.mean(precision_list),",
      "        np.mean(recall_list),",
      "        np.mean(f1_list)",
      "    )"
    ],
    "description": "Classification metrics"
  },

  "Plot Loss Graph": {
    "prefix": "$15",
